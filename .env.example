# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string (Railway provides this automatically for its Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Monthly subscription price in Telegram Stars (paid via native Stars invoices,
# no payment provider needed)
SUBSCRIPTION_STARS=250

# Comma-separated telegram ids that always transcribe for free (optional override)
FREE_USER_IDS=540529430,1115719673

# Comma-separated telegram ids that receive alerts and can use /stats
ADMIN_USER_IDS=540529430

# Netscape-format cookies.txt content for yt-dlp — required for Instagram
# (rate-limits anonymous downloads) and helps with YouTube's bot checks.
# Export for BOTH instagram.com and youtube.com. Base64-encoded is safest.
YTDLP_COOKIES=

# Optional proxy for yt-dlp downloads, e.g. a residential proxy when YouTube
# blocks the hoster's datacenter IPs. Format: http://user:pass@host:port
PROXY_URL=
