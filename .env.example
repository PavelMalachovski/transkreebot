# Telegram bot token from @BotFather
BOT_TOKEN=

# PostgreSQL connection string (Railway provides this automatically for its Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram Payments provider token for Stripe, issued by @BotFather (Bot Settings -> Payments)
PAYMENTS_PROVIDER_TOKEN=
# Alias for the same token; PAYMENTS_PROVIDER_TOKEN takes precedence if both are set
STRIPE_TOKEN=

# Comma-separated telegram ids that always transcribe for free (optional override)
FREE_USER_IDS=540529430,1115719673

# Netscape-format cookies.txt content for yt-dlp — required for Instagram, which
# rate-limits anonymous downloads. Export cookies from a logged-in browser session.
YTDLP_COOKIES=
